# Supabase — обязательно
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role — только для крона проверки новых серий
# (src/app/api/cron/check-episodes). Обходит RLS, читает user_list ВСЕХ
# пользователей. Берётся в Supabase: Project Settings → API → service_role.
# СЕКРЕТНЫЙ ключ — никогда не должен попасть в клиентский код/NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Секрет крона: Vercel сам добавляет заголовок Authorization: Bearer
# $CRON_SECRET к запросам по расписанию (см. vercel.json) — этим же
# значением эндпоинт /api/cron/check-episodes отличает настоящий крон-вызов
# от постороннего запроса. Сгенерируйте любую случайную строку.
CRON_SECRET=

# Kodik — опционально (Режим A: серверное проксирование поиска плеера).
# Токен бесплатный, выдаётся по запросу. Без него включается fallback (Режим B).
# Также используется как каталог раздела «Фильмы и сериалы» (эндпоинты /list и
# /search): без токена этот раздел показывает заглушку. Кладите значение в .env.local.
KODIK_TOKEN=

# Videoseed — основной плеер раздела «Фильмы и сериалы».
# Это «Ключ API плеера» из кабинета Videoseed (НЕ «Ключ API» — тот для apiv2.php,
# который мы не используем). Подставляется в ?token= в embed_auto по kinopoisk_id.
# Без него в кино доступен только Kodik (переключатель плеера скрыт).
# ВНИМАНИЕ: по дизайну провайдера этот токен попадает в src iframe и виден в
# браузере — это публичный embed-токен, так и задумано.
VIDEOSEED_TOKEN=

# Videoseed API v2 — каталог раздела «Фильмы и сериалы» (список/поиск/карточка).
# Это «Ключ API» из кабинета (32 символа), НЕ ключ плеера. Ходит на apiv2.php.
# Без него раздел кино показывает заглушку. Учтите: у API есть квота запросов,
# поэтому ответы кэшируются.
VIDEOSEED_API_TOKEN=

# Опционально: домен Videoseed, привязанный к аккаунту (виден в «Шаблоне
# embed-кода» в кабинете). По умолчанию tv-1-kinoserial.net.
VIDEOSEED_HOST=

# Vibix — плеер с ТОЧНЫМ трекингом позиции (его Playerjs шлёт postMessage-события).
# Bearer-токен API из личного кабинета vibix.org (формат id|секрет). Приватный,
# используется только на сервере (/api/v1/publisher/videos/kp/{kpId}).
# Без него пункт Vibix в переключателе плеера не показывается.
VIBIX_TOKEN=

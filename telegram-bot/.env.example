# Telegram Bot
BOT_TOKEN=ваш_токен_бота

# Telegram Local Bot API (опционально, для файлов > 50 МБ)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://ваш_проект.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ваш_service_role_key

# Videoseed (для извлечения видео-URL)
VIDEOSEED_TOKEN=
VIDEOSEED_HOST=

# Yummy/Alloha не требует токенов

# AniLibria не требует токенов

# Лимиты
CONCURRENCY=1
MAX_FILE_SIZE_BYTES=1500000000
TIMEOUT_MS=900000
